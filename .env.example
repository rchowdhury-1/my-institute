# ── Backend URL (required) ────────────────────────────────────────────────────
# Set to your Render backend URL in production
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── Production site URL ───────────────────────────────────────────────────────
# Used in sitemap, robots.txt, og: tags
NEXT_PUBLIC_SITE_URL=https://my-institute-eight.vercel.app

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
CONTACT_EMAIL=myinstitute2026@gmail.com

# ── Sentry error tracking (optional) ─────────────────────────────────────────
# Get your DSN from sentry.io → Project → Settings → Client Keys
# Leave blank to disable Sentry. Install @sentry/nextjs first: npm install @sentry/nextjs
NEXT_PUBLIC_SENTRY_DSN=

# ── Phase 2B feature flags ────────────────────────────────────────────────────
# All default to OFF (false). Set to 'true' to enable when ready.
# See HANDOVER.md for what each flag controls.
NEXT_PUBLIC_FEATURE_EXAMS=false
NEXT_PUBLIC_FEATURE_TEACHER_SALARY=false
NEXT_PUBLIC_FEATURE_RECORDED_COURSES=false
NEXT_PUBLIC_FEATURE_MESSAGING=false
NEXT_PUBLIC_FEATURE_SCHOLARSHIP_SPONSORSHIP=false
