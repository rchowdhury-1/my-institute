PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Use Neon Transaction Pooler URL (port 6543) for Render deployment
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
CONTACT_EMAIL=admin@yourdomain.com

# ── URLs ──────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ── Sentry error tracking (optional) ─────────────────────────────────────────
# Get your DSN from sentry.io → Project → Settings → Client Keys
# Leave blank to disable. Install @sentry/node first: npm install @sentry/node
SENTRY_DSN=

# ── Phase 2B feature flags ────────────────────────────────────────────────────
# All default to OFF. Set to 'true' when ready to enable each system.
# Disabled routes return 404. See HANDOVER.md for details.
FEATURE_EXAMS=false
FEATURE_TEACHER_SALARY=false
FEATURE_MESSAGING=false
FEATURE_RECORDED_COURSES=false
FEATURE_SCHOLARSHIP_SPONSORSHIP=false
